class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n=nums.length;
        int pre[]=new int[n];
        pre[0]=nums[0];
        for(int i=1;i<n;i++){
            pre[i]=pre[i-1]+nums[i];
        }
        int su[]=new int[n];
        su[n-1]=nums[n-1];
        for(int i=n-2;i>=0;i--)
{
    su[i]=su[i+1]+nums[i];
}   
int dif[]=new int[n];
for(int i=0;i<n;i++){
    dif[i]=Math.abs(pre[i]-su[i]);

}
return dif;
 }
}
